{
  "version": 2,
  "name": "verrel2053",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "trailingSlash": false,
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": ".",
  "regions": [
    "dub1"
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 128
    }
  }
}
